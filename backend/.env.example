# ─── Banco de Dados ────────────────────────────────────────────────
DATABASE_URL=postgresql://user:senha@host/dbname?sslmode=require

# ─── Servidor ──────────────────────────────────────────────────────
PORT=3001

# ─── WhatsApp (Evolution API) ──────────────────────────────────────
# Mesmas credenciais configuradas no Vysify (Super Admin → Evolution API)
# O Scoutly envia pelo mesmo número. Respostas caem na Inbox do Vysify.
EVOLUTION_API_URL=https://sua-evolution-api.up.railway.app
EVOLUTION_API_KEY=sua_chave_global_da_evolution
EVOLUTION_INSTANCE=vysify-SEU_WORKSPACE_ID

# ─── SMS / Voz (Twilio) ────────────────────────────────────────────
# Mesmas credenciais e número configurados no Vysify.
# O Scoutly envia pelo mesmo número. Respostas caem na Inbox do Vysify.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=seu_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
